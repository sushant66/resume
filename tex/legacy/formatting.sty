\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{formatting}[2026/04/30 Sushant resume formatting helpers]

\RequirePackage[dvipsnames]{xcolor}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{array}
\PassOptionsToPackage{hidelinks}{hyperref}
\RequirePackage{hyperxmp}
\RequirePackage{geometry}
\RequirePackage{etoolbox}
\RequirePackage{microtype}
\RequirePackage{datetime2}
\RequirePackage{embedfile}

\geometry{
  letterpaper,
  top=0.4in,
  bottom=0.4in,
  left=0.4in,
  right=0.4in
}

\raggedright
\pagestyle{empty}
\input{glyphtounicode}
\pdfgentounicode=1

% PDF/UA - mark document as tagged for accessibility
\pdfminorversion=7
\pdfobjcompresslevel=0

\@ifclassloaded{resume}{}{%
  \RequirePackage{enumitem}
  \RequirePackage[hidelinks]{hyperref}
  \RequirePackage{titlesec}
  \titleformat{\section}
    {\bfseries\large}{}{}{}[\vspace{-3pt}\titlerule]

  \renewcommand\labelitemi{$\vcenter{\hbox{\small$\bullet$}}$}
  \setlist[itemize]{
    itemsep=-3pt,
    leftmargin=14pt,
    topsep=3pt
  }

  \setlength{\parskip}{0pt}
  \setlength{\parindent}{0pt}
}

\newcommand{\tab}[1]{\hspace{.2667\textwidth}\rlap{#1}}
\newcommand{\itab}[1]{\hspace{0em}\rlap{#1}}

\@ifclassloaded{resume}{}{%
  \newcommand{\name}[1]{%
    \centerline{\Huge\bfseries #1}
    \vspace{4pt}
  }

  \newcommand{\address}[1]{%
    \begin{center}
      #1
    \end{center}
    \vspace{-8pt}
  }

  \newenvironment{rSection}[1]{%
    \vspace{5pt}
    \section*{#1}
    \vspace{-2pt}
  }{%
    \vspace{2pt}
  }
}

\newcommand{\educationentry}[4]{%
  {\bfseries #2}, #1 \hfill {#3}\\
  #4
}

\newcommand{\experienceposition}[2]{%
  \textbf{#1} \hfill #2 \\
}

\newcommand{\experiencecompany}[2]{%
  \textit{#1} \hfill #2
}

\newcommand{\experienceentry}[4]{%
  \experienceposition{#3}{#4}
  \experiencecompany{#1}{#2}
  \begin{itemize}
}

\newcommand{\experienceentryend}{%
  \end{itemize}
}

\newcommand{\projectheading}[4]{%
  \ifstrempty{#3}{%
    \textbf{#1}\ifstrempty{#2}{}{, #2}%
  }{%
    \textbf{#1}\ifstrempty{#2}{}{, #2} \hfill \href{#3}{#4}%
  }\\[-2pt]
}

\newcommand{\projectentry}[4]{%
  \projectheading{#1}{#2}{#3}{#4}
  \begin{itemize}
}

\newcommand{\projectentryend}{%
  \end{itemize}
}

\newcommand{\projectlink}[2]{\href{#1}{#2}}
\newcommand{\skillline}[2]{\textbf{#1:} #2 \\}
